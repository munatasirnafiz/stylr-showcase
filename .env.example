# Public — safe to expose to the browser bundle (Vite only exposes VITE_-prefixed vars)
VITE_SANITY_PROJECT_ID=yczlvuot
VITE_SANITY_DATASET=production

# Secret — used only by scripts/seed.ts, never prefix with VITE_, never commit the real value.
# Create a token with "Editor" (write) permissions at https://sanity.io/manage -> your project -> API -> Tokens
SANITY_API_WRITE_TOKEN=

# Public — Supabase project URL + anon key, used for auth and user data (profiles,
# favorites, inquiries, delivery addresses). Create a project at https://supabase.com,
# then copy these from Project Settings -> API. Run supabase/migrations/0001_init.sql
# in the Supabase SQL editor to create the required tables.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
