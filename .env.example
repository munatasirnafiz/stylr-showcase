# Public — safe to expose to the browser bundle (Vite only exposes VITE_-prefixed vars)
VITE_SANITY_PROJECT_ID=yczlvuot
VITE_SANITY_DATASET=production

# Secret — used only by scripts/seed.ts, never prefix with VITE_, never commit the real value.
# Create a token with "Editor" (write) permissions at https://sanity.io/manage -> your project -> API -> Tokens
SANITY_API_WRITE_TOKEN=
